# FinAgent MVP - Environment Configuration

# ============================================================================
# Service URLs
# ============================================================================
OLLAMA_HOST=http://ollama:11434
POSTGRES_DSN=postgresql://finagentagent:finagentagent_dev_pwd_123@postgres:5432/finagentagent_db
ALTERNATE_LOCAL_MODEL=gemma:2b
REDIS_URL=redis://redis:6379/0

# ==========================================================================
# Local LLM Models
# ==========================================================================
# Update tags only if your local Ollama host uses different names.
# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================================================
# Model Configuration
# ============================================================================
# Local model (Ollama)
LOCAL_MODEL=mistral
LOCAL_MODEL_TIMEOUT_SECONDS=120

# Cloud model (mock for MVP)
CLOUD_MODEL=gpt-3.5-turbo
CLOUD_API_KEY=sk-mock-api-key-xyz
CLOUD_API_TIMEOUT_SECONDS=60

# Model policy default
DEFAULT_MODEL_POLICY=hybrid

# ============================================================================
# Audit & Observability
# ============================================================================
AUDIT_DB_PATH=/data/audit.db
AUDIT_LOG_RETENTION_DAYS=7

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================================================
# Secrets (Env-based for MVP)
# ============================================================================
# All secrets are resolved via environment variables for MVP.
# No external Vault service is required.

# Core Banking / PostgreSQL
CORE_BANKING_HOST=postgres
CORE_BANKING_RO_CREDS=finagentagent:finagentagent_dev_pwd_123

# Cloud API (mock for MVP)
OPENAI_API_KEY=sk-mock-api-key
CLOUD_API_KEY=mock-cloud-api-key

# ============================================================================
# Session & Memory
# ============================================================================
SESSION_TIMEOUT_MINUTES=60
SESSION_CHECKPOINT_INTERVAL=2  # checkpoint after every N tool calls
MEM0_API_KEY=mock_mem0_key_xyz
MEM0_ORG_ID=mock_mem0_org_id

# ============================================================================
# Connector Configuration
# ============================================================================
# PostgreSQL demo connector
POSTGRES_QUERY_TIMEOUT_SECONDS=30
POSTGRES_MAX_ROWS_RETURNED=1000

# REST API connector
REST_TIMEOUT_SECONDS=30
REST_MAX_RETRIES=3

# ============================================================================
# Security
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
JWT_SECRET=dev_jwt_secret_xyz_do_not_use_in_production
JWT_ALGORITHM=HS256

# ============================================================================
# Logging
# ============================================================================
LOG_FORMAT=json  # json or text
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/finagentagent/app.log

# ============================================================================
# Development/Testing
# ============================================================================
MOCK_CONNECTORS=false  # Use real connectors once implementation starts
SKIP_AUTH=true  # Skip authentication for development
AUTO_MIGRATE_DB=true  # Auto-run migrations on startup

# ============================================================================
# Local LLM Models (to be determined based on system capability)
# ============================================================================
# LOCAL_MODEL will be set based on available Ollama models after system check
# Expected options: mistral, gemma3, etc.
LOCAL_MODEL=mistral
ALTERNATE_LOCAL_MODEL=gemma3
